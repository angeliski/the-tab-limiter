{
	"manifest_version": 3,
	"name": "The Tab Limiter",
	"version": "0.3.2",
	"description": "Limit the number of open tabs – in total and per window",

	"author": "Rogerio Angeliski",
	"homepage_url": "https://github.com/angeliski/the-tab-limiter",
	"icons": {
		"48": "icons/48.png",
		"128": "icons/128.png"
	},
	"action": {
		"default_icon": {
			"48": "icons/48.png",
			"128": "icons/128.png"
		},
		"default_popup": "options.html",
		"default_title": "The Tab Limiter"
	},
	"options_ui": {
		"page": "options.html",
		"open_in_tab": false
	},
	"background": {
		"service_worker": "background.js"
	},
	"permissions": [
		"storage",
		"notifications"
	]
}